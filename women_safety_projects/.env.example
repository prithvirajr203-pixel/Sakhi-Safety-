# Example Environment Variables

# Application Settings
APP_NAME=Sakhi-Safety
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Database Settings
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=my_database
DB_USERNAME=my_username
DB_PASSWORD=my_password

# API Keys
API_KEY=your_api_key_here
